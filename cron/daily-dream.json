{
  "name": "Daily Memory Dream",
  "description": "每日记忆复盘 - 自动提炼L0会话生成L1情景记忆",
  "schedule": "0 23 * * *",
  "task": "node ~/.openclaw/workspace/agent-memory-os/scripts/daily-dream.mjs",
  "output": {
    "format": "json",
    "path": "~/.openclaw/workspace/memory/dreams/logs"
  },
  "retry": {
    "maxAttempts": 3,
    "delay": "5m"
  },
  "notifications": {
    "onFailure": true,
    "onSuccess": false
  },
  "resources": {
    "timeout": "5m",
    "memory": "512MB"
  }
}
